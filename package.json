{
  "name": "xls-export",
  "version": "0.1.0",
  "description": "Angular 21 compatible XLSX exporter with zero external dependencies.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
